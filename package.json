{
  "name": "human-to-code",
  "version": "0.1.39",
  "description": "Turn plain-language .human files and @human markers into code.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "human-to-code": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "assets",
    "docs",
    "Readme.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@types/node": "24.13.3",
    "typescript": "5.9.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "node src/cli.ts",
    "start": "node dist/cli.js",
    "test": "node --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "package:check": "npm run build && node test/package-smoke.mjs",
    "prepack": "npm run clean && npm run build"
  },
  "keywords": [
    "codegen",
    "compiler",
    "llm",
    "natural-language",
    "dsl"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {}
}
